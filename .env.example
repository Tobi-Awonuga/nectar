# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nectar
POSTGRES_PASSWORD=nectar
POSTGRES_DB=nectar

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Local dev (outside Docker) — drizzle-kit connects via localhost
# Inside Docker this is overridden by docker-compose to use the 'postgres' service name
DATABASE_URL=postgresql://nectar:nectar@localhost:5432/nectar
JWT_SECRET=

# ── Microsoft SSO (Azure AD) ──────────────────────────────────────────────────
AZURE_CLIENT_SECRET=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# ── Frontend (Vite — VITE_ prefix required to expose to browser) ──────────────
VITE_API_BASE_URL=/api
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
