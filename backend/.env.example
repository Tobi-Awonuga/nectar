# Used by drizzle-kit commands run locally (outside Docker)
# Note: when running inside Docker, DATABASE_URL is injected by docker-compose
DATABASE_URL=postgresql://nectar:nectar@localhost:5432/nectar

NODE_ENV=development
PORT=3000

JWT_SECRET=change-me-must-be-at-least-32-characters-long

# Microsoft SSO — fill in after registering the app in Azure AD
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
